# Copy this file to .env for local development, then adjust values as needed.

POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=civicwatch_explore
POSTGRES_USER=postgres
DATABASE_URL=postgres://postgres@localhost:55432/civicwatch_explore

API_HOST=127.0.0.1
API_PORT=4000
API_BASE_URL=http://127.0.0.1:4000/api/v1
PUBLIC_API_BASE_URL=http://127.0.0.1:4000/api/v1

# Used by scripts/start-civicwatch.sh --production.
WEB_HOST=127.0.0.1
WEB_PORT=3000
