# Copy this file to .env for local development, then adjust values as needed.

POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=civicwatch_explore
POSTGRES_USER=postgres
DATABASE_URL=postgres://postgres@localhost:55432/civicwatch_explore
CIVICWATCH_START_LOCAL_POSTGRES=auto

# Production-compatible database aliases are also supported by the Bash launcher
# and API. If DB_PASSWORD contains URI-special characters, prefer DATABASE_URL.
# If you use DB_* in production, remove or comment out the local DATABASE_URL.
# DB_HOST=picso102.sci.pitt.edu
# DB_PORT=5432
# DB_NAME=civicwatch
# DB_USER=civicwatch
# DB_PASSWORD=replace-me

API_HOST=127.0.0.1
API_PORT=4000
# PORT is accepted as an API_PORT alias for prototype-style deployments.
# PORT=4000
API_BASE_URL=http://127.0.0.1:4000/api/v1
PUBLIC_API_BASE_URL=http://127.0.0.1:4000/api/v1
PUBLIC_BASE_PATH=

# Used by scripts/start-civicwatch.sh --production.
WEB_HOST=127.0.0.1
WEB_PORT=3000
